# =============================================================================
# LOGBACK LEARNING REPOSITORY - CLEAN ENVIRONMENT
# =============================================================================
# DENY ALL APPROACH: Ignore everything by default
# =============================================================================
*

# 🚨 Allow directories (essential to recurse into subdirectories)
!**/

# 📄 Root Project Files
!.gitignore
!README.md
!LICENSE

# 📁 logback-basic module
!logback-basic/src/**
!logback-basic/gradle/**
!logback-basic/build.gradle.kts
!logback-basic/settings.gradle.kts
!logback-basic/gradle.properties
!logback-basic/gradlew
!logback-basic/gradlew.bat
!logback-basic/README.md

# =============================================================================
# 🛑 EXCLUSIONS (Items that should NEVER be tracked)
# =============================================================================

# Gradle directories
.gradle/
build/
out/
bin/

# IDE files
.vscode/
.idea/
*.iml
.project
.classpath
.settings/

# OS/System files
.DS_Store
Thumbs.db

# Logs & Binaries
logs/
*.log
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# VM crash logs
hs_err_pid*
replay_pid*
