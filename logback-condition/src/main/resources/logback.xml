<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 1. Conditional Configuration starts here -->
    <!-- We check the system property 'APP_ENV' -->
    <if condition='property("APP_ENV").contains("PROD")'>
        <then>
            <!-- PRODUCTION SETTINGS -->
            <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
                <encoder>
                    <pattern>%d{HH:mm:ss.SSS} [PROD] %-5level %logger{36} - %msg%n</pattern>
                </encoder>
            </appender>
            <root level="WARN">
                <appender-ref ref="CONSOLE" />
            </root>
        </then>
        <else>
            <!-- DEVELOPMENT SETTINGS (Default) -->
            <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
                <encoder>
                    <pattern>%d{HH:mm:ss.SSS} [%thread] %highlight(%-5level) %cyan(%logger{36}) - %msg%n</pattern>
                </encoder>
            </appender>
            <root level="DEBUG">
                <appender-ref ref="CONSOLE" />
            </root>
        </else>
    </if>

</configuration>